# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# Resend API key — used by the contact form to send emails.
# Get yours at https://resend.com (free tier: 3,000 emails/month).
RESEND_API_KEY=your_resend_api_key_here

# The email address that contact form submissions are delivered to.
CONTACT_TO_EMAIL=your@email.com
