# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

/public/cv.pdf

# Large binaries — hosted on GitHub Releases, not served from the repo
/public/backgammon/*.exe
/public/backgammon/*.zip

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — real secrets stay local, example is committed as documentation
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Editor
.vscode/
.curser/
.claude/
.claude-flow/
.gstack/

